// stemfont.k — extended 8x16 bitmap font: ASCII (k:wayland) + Latin-1, box,
// block, arrows, powerline separators+caps, Nerd icons (+rust/python), and a
// hand-drawn krypton atom (U+E900). Rasterized from JetBrainsMono Nerd Font.
import "k:wayland"

func stemExtHex() { emit "" }

func _stemNib(cc) {
    if cc >= 48 && cc <= 57 { emit cc - 48 }
    emit cc - 87
}
func stemFontLoad() {
    let hex = wlFontHex() + stemExtHex()
    let n = len(hex) / 2
    let b = bufNew(n)
    let i = 0
    while i < n {
        bufSetByte(b, i, _stemNib(toInt(charCode(substring(hex, i * 2, i * 2 + 1)))) * 16 + _stemNib(toInt(charCode(substring(hex, i * 2 + 1, i * 2 + 2)))))
        i = i + 1
    }
    emit b
}
func stemGlyphIdx(cp) {
    if cp >= 32 && cp <= 126 { emit cp - 32 }
    if cp >= 160 && cp <= 255 { emit 95 + 0 + (cp - 160) }
    if cp >= 9472 && cp <= 9599 { emit 95 + 96 + (cp - 9472) }
    if cp >= 9600 && cp <= 9631 { emit 95 + 224 + (cp - 9600) }
    if cp >= 8592 && cp <= 8607 { emit 95 + 256 + (cp - 8592) }
    if cp >= 57520 && cp <= 57527 { emit 95 + 272 + (cp - 57520) }   // powerline E0B0-E0B7
    if cp == 57504 { emit 95 + 280 }    // E0A0 git branch
    if cp == 57506 { emit 95 + 281 }    // E0A2 lock
    if cp == 61461 { emit 95 + 282 }    // F015 home
    if cp == 61563 { emit 95 + 283 }    // F07B folder
    if cp == 61595 { emit 95 + 284 }    // F09B github
    if cp == 61641 { emit 95 + 285 }    // F0C9 menu
    if cp == 61728 { emit 95 + 286 }    // F120 terminal
    if cp == 59138 { emit 95 + 287 }    // E702 branch
    if cp == 61715 { emit 95 + 288 }    // F113
    if cp == 61907 { emit 95 + 289 }    // F1D3 git
    if cp == 59304 { emit 95 + 290 }    // E7A8 rust
    if cp == 59196 { emit 95 + 291 }    // E73C python
    if cp == 59648 { emit 95 + 292 }    // E900 krypton (custom atom)
    emit 0 - 1
}
func stemDrawChar(px, fbW, fbH, font, x, y, code, color) {
    let gi = stemGlyphIdx(code)
    if gi < 0 { emit 0 }
    let off = gi * 16
    let b = color - color / 256 * 256
    let g = color / 256 - color / 65536 * 256
    let r = color / 65536 - color / 16777216 * 256
    let row = 0
    while row < 16 {
        let bits = toInt(bufGetByte(font, off + row))
        let py = y + row
        if py >= 0 && py < fbH {
            let mask = 128
            let col = 0
            while col < 8 {
                let bit = bits / mask
                if bit - bit / 2 * 2 == 1 {
                    let pxx = x + col
                    if pxx >= 0 && pxx < fbW {
                        let o = (py * fbW + pxx) * 4
                        bufSetByte(px, o, b)  bufSetByte(px, o + 1, g)
                        bufSetByte(px, o + 2, r)  bufSetByte(px, o + 3, 0)
                    }
                }
                mask = mask / 2
                col = col + 1
            }
        }
        row = row + 1
    }
    emit 1
}
